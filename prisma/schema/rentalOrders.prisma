model RentalOrder {
  id String @id @default(uuid())

  customerId String
  providerId String
  gearId String
  

  startDate     DateTime
  endDate       DateTime
  totalDays     Int
  quantity   Decimal
  transactionId String?

  pricePerDay   Decimal
  totalAmount   Decimal

  status        RentalStatus @default(PLACED)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt


  customer      User          @relation("CustomerOrders", fields: [customerId], references: [id])
  provider      User          @relation("ProviderOrders", fields: [providerId], references: [id])
  gear          Gear @relation(fields: [gearId],references: [id])
}