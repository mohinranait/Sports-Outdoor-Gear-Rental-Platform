model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  role      Role       @default(Customer)
  status    UserStatus @default(activate)
  phone     String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now())

  gears Gear[]
}
